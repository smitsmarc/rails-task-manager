<div class="container mt-4">

<h1> Edit task</h1>
<%= form_with model: @task do |f| %>
  <%= f.label :title %>
  <%= f.text_field :title %>
  <%= f.label :details %>
  <%= f.text_field :details %>
  <%= f.label :completed %>
  <%= f.check_box :completed %>
  <%= f.submit "Update task" %>

<div class="container mt-5">
  <%= link_to "Back", tasks_path, class: "btn btn-primary" %>
  </div>
  <% end %>
</div>
