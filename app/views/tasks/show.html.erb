<div class="container mt-4">

<h1> <%= @task.title %> </h1>
<p> <%= @task.details %> </p>

  <div class="d-flex gap-2 mt-5">
    <%= link_to "Edit", edit_task_path(@task), class: "btn btn-warning" %>
    <%= link_to "Delete", destroy_task_path(@task), data: { turbo_method: :delete }, class: "btn btn-danger" %>
    <%= link_to "Back", tasks_path, class: "btn btn-primary" %>
  </div>
</div>
